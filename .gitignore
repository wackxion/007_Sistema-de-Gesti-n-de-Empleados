# ============================================================
# Archivos y carpetas a ignorar en Git
# Protege credenciales y archivos sensibles
# ============================================================

# ---------------------------------------------------
# Archivos de configuración con credenciales
# ---------------------------------------------------
.env
.env.local
.env.*.local

# ---------------------------------------------------
# Python
# ---------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ---------------------------------------------------
# Entornos virtuales
# ---------------------------------------------------
venv/
env/
ENV/
.venv

# ---------------------------------------------------
# IDEs y editores
# ---------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ---------------------------------------------------
# Logs y archivos temporales
# ---------------------------------------------------
*.log
*.tmp
temp/
tmp/

# ---------------------------------------------------
# Base de datos SQLite (si se usa en desarrollo)
# ---------------------------------------------------
*.db
*.sqlite
*.sqlite3
